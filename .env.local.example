# Sanity CMS sozlamalari
# sanity.io/manage saytidan oling

# Loyiha ID (majburiy)
NEXT_PUBLIC_SANITY_PROJECT_ID=your_project_id_here

# Dataset nomi (odatda "production")
NEXT_PUBLIC_SANITY_DATASET=production

# Sanity API token (faqat server tomonida, write uchun)
# sanity.io/manage → API → Tokens → Add API token → Editor roli
SANITY_API_TOKEN=your_token_here

# Sanity webhook secret (ixtiyoriy, revalidation uchun)
SANITY_WEBHOOK_SECRET=your_webhook_secret_here
