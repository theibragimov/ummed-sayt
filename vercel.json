{
  "regions": ["hnd1"],
  "crons": [
    {
      "path": "/api/moysklad/sync?secret=ummed-cron-secret-2024",
      "schedule": "0 * * * *"
    }
  ],
  "headers": [
    {
      "source": "/studio/(.*)",
      "headers": [
        {
          "key": "X-Frame-Options",
          "value": "SAMEORIGIN"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        }
      ]
    }
  ]
}
